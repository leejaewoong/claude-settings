2250\" /><p local-id=\"badacb99-180d-4dfa-bf66-2853e3881792\" /></ac:layout-cell></ac:layout-section><ac:layout-section ac:type=\"single\" ac:breakout-mode=\"default\" ac:local-id=\"53641594-7cb3-4bbe-9a96-7267869c5a4e\"><ac:layout-cell ac:local-id=\"aa6f9ff5-9250-442e-9225-f4f2767c5fe6\"><h1 local-id=\"b907dbea-96a1-418a-8672-e72f47a8f99f\">정의</h1><p local-id=\"f2b6bd0b-d98b-4851-a9fe-881bd32d5b8d\"><ac:structured-macro ac:name=\"status\" ac:schema-version=\"1\" ac:macro-id=\"0e8ed73f-34b8-4fd3-b14b-b51ce7106703\"><ac:parameter ac:name=\"title\">Elements</ac:parameter><ac:parameter ac:name=\"colour\">Green</ac:parameter></ac:structured-macro>  아이템 유효 기간, 이벤트 기간 등 남은 시간을 표시하는 컴포넌트</p><p local-id=\"7c17d4a9-018c-40e9-ac40-67b248358da4\" /><ac:image ac:align=\"left\" ac:layout=\"align-start\" ac:original-height=\"345\" ac:original-width=\"919\" ac:custom-width=\"true\" ac:local-id=\"d0fcea89-c184-4e3d-8394-bb0db80c727a\" ac:alt=\"image-20251119-045621.png\" ac:width=\"919\"><ri:attachment ri:filename=\"image-20251119-045621.png\" ri:version-at-save=\"1\" /></ac:image></ac:layout-cell></ac:layout-section><ac:layout-section ac:type=\"single\" ac:breakout-mode=\"default\" ac:local-id=\"e22e3c5a-4f1f-45e2-9676-21d619149ca3\"><ac:layout-cell ac:local-id=\"5baa0b8f-3ef5-4c23-bb43-0eb8f893cb0a\"><p local-id=\"a838a704-e835-431c-97ea-46eb3cbbd051\" /></ac:layout-cell></ac:layout-section><ac:layout-section ac:type=\"single\" ac:breakout-mode=\"default\" ac:local-id=\"2df3d9a5-c689-4021-8ce0-7d1baddce0a2\"><ac:layout-cell ac:local-id=\"3ee81282-b5b5-4d00-b20d-f660dfcff6fc\"><h1 local-id=\"559c5242-580a-489c-aa35-f1719b898d40\">개발 사양</h1><h2 local-id=\"6eb144d7-488e-434c-8d9f-02131bd52ae2\">일반 규칙</h2><h3 local-id=\"31918b77-647e-4ffd-ace2-055a77e03a78\"><strong>시간 갱신</strong></h3><ul local-id=\"98cfda62-2d34-4d73-b047-b7c9028c8759\"><li local-id=\"290bd6ee-be51-4bda-b21c-866baa3a598e\"><p local-id=\"9ae250e6-718c-4d6b-acc5-2a8b07bff62d\">1초마다 동기화되어 자동 갱신</p><ul local-id=\"91ca41b9-109c-477e-a73a-90609f4b92d0\"><li local-id=\"90b889f0-812e-49f7-9c7a-9ecfce5b5c20\"><p local-id=\"f78fa812-7568-4d81-9539-104a873f4e5a\">현재는 1분 단위로 갱신중 &rarr; 초단위로 갱신 예정</p></li></ul></li></ul><h3 local-id=\"17b73001-118f-40bd-8530-0bb4f87382cf\"><strong>시간 표기</strong></h3><ul local-id=\"b8be5371-7edf-433c-a0b2-c5e35ee55519\"><li local-id=\"dd3dc537-b0cf-4698-9828-15249275a29b\"><p local-id=\"fc7da370-a90f-48c4-b36c-9253cc850317\"><strong>d/h/m 는 소문자로 표시</strong>해서 숫자와 혼동되지 않게 함 , 상위 시간이 0이면 상위시간을 생략(0d &rarr; 59h 59m표기)</p></li><li local-id=\"49d85fa0-78b4-481b-bc26-6466026efb2f\"><p local-id=\"0b19a502-7567-4311-885c-3689f7e6ed95\"><strong> 1분 이하</strong>일 때 <strong>s(초단위) 표기</strong>로 결정 </p></li><li local-id=\"aa2cd59e-b029-4b2c-9100-3ddfff3cb871\"><p local-id=\"b57792d2-09c1-4eee-b099-09fc835baf8a\">기본 / 7일 전 / 기간 만료의 3단계 스타일 적용</p></li></ul><h3 local-id=\"062ffeeb-9986-4777-a951-dd6f876d91bf\"><strong>기타</strong></h3><ul local-id=\"d6b1cd25-8a02-4098-bcdf-e1ec1d1dc195\"><li local-id=\"41edd031-d713-4866-8abd-72cac9be30f0\"><p local-id=\"79e0c754-bd50-4a79-a343-0c4c4a02bfe4\">시간 외에 별도 '매개 변수{0}'를 넣지 않는다.</p></li><li local-id=\"192b1dc9-b740-44ce-a540-4ce9d038b8cf\"><p local-id=\"b171a732-8a8c-48ec-ae32-2aae4b09276e\"><ac:inline-comment-marker ac:ref=\"0aa6f8ca-521b-4fdc-80fb-a3c6785c6d16\">순수한 시간 정보 외의 추가적인 정보가 필요할 경우 기본형의 앞, 뒤에 간단한 문구를 추가 할 수 있다. </ac:inline-comment-marker></p></li><li local-id=\"9ce1d234-550a-412d-a354-fbbc258bb9ad\"><p local-id=\"d6bd7605-4da6-47a9-95cb-f22de45c075b\">타임 인디케이터에 태그 스타일을 사용할 수 있다.</p></li></ul><p local-id=\"9e952413-eb6a-4e39-a4c5-ec29b30c3a75\" /><h2 local-id=\"f9b9f0f9-7665-424a-88d4-8dd6a2131339\">속성별 규칙</h2><table data-table-width=\"939.3912\" data-layout=\"wide\" ac:local-id=\"518ac1e6-e2e6-4fe2-8d52-b3d882c1a327\"><colgroup><col style=\"width: 117.0px;\" /><col style=\"width: 101.0px;\" /><col style=\"width: 500.0px;\" /></colgroup><tbody><tr ac:local-id=\"f1e8c497-4d8f-42f3-8a05-6511197b3f88\"><th ac:local-id=\"b42f2