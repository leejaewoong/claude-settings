{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep",
      "NotebookEdit",
      "WebFetch",
      "mcp__figma__get_screenshot",
      "mcp__figma__get_metadata",
      "mcp__figma__get_design_context",
      "mcp__figma__get_variable_defs",
      "mcp__figma__get_code_connect_map",
      "mcp__figma__get_code_connect_suggestions",
      "mcp__figma__create_design_system_rules",
      "mcp__figma__generate_figma_design",
      "mcp__figma__generate_diagram",
      "mcp__figma__whoami",
      "mcp__figma__get_figjam",
      "mcp__figma__add_code_connect_map",
      "mcp__figma__send_code_connect_mappings",
      "mcp__figma-dev-mode-mcp-server__get_screenshot",
      "mcp__figma-dev-mode-mcp-server__get_metadata",
      "mcp__figma-dev-mode-mcp-server__get_design_context",
      "mcp__figma-dev-mode-mcp-server__get_variable_defs",
      "mcp__figma-dev-mode-mcp-server__get_code_connect_map",
      "mcp__figma-dev-mode-mcp-server__create_design_system_rules",
      "mcp__claude_ai_Figma__create_new_file",
      "mcp__claude_ai_Figma__use_figma",
      "Bash(claude mcp *)",
      "Skill(update-config)",
      "Skill(update-config:*)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)"
    ]
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'bash ~/.claude/hooks/session_sync_claude.sh'"
          },
          {
            "type": "command",
            "command": "bash -c 'bash ~/.claude/hooks/register_pubg_credential.sh'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'python ~/.claude/hooks/bash_safelist_check.py'"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'bash ~/.claude/hooks/revise_claude_trigger.sh'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "figma@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true,
    "gitlab@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "firebase@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "krafton-order@pubg-claude-marketplace": true,
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "comfy-cloud@comfy-skills": true
  },
  "extraKnownMarketplaces": {
    "pubg-claude-marketplace": {
      "source": {
        "source": "git",
        "url": "https://claude-marketplace.pubg.io/repo.git"
      }
    },
    "comfy-skills": {
      "source": {
        "source": "github",
        "repo": "Comfy-Org/comfy-skills"
      }
    }
  },
  "autoUpdatesChannel": "latest",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-daltonized",
  "agentPushNotifEnabled": true
}
