# Confluence API Token
# https://id.atlassian.com/manage-profile/security/api-tokens 에서 생성
CONFLUENCE_API_TOKEN=your-api-token-here
CONFLUENCE_CLOUD_ID=your-cloud-id-here

# Confluence Base URL
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net/

# Confluence Email (Basic Auth용)
CONFLUENCE_EMAIL=your@email.com

# PUBG Claude Marketplace API Key (hooks/git-credential-pubg.sh가 읽음)
PUBG_MARKETPLACE_API_KEY=your-marketplace-api-key-here
